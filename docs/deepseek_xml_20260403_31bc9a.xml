        <omgdc:Bounds x="2880" y="155" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="2870" y="212" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_CreateReprogramDispatch" bpmnElement="Task_CreateReprogramDispatch">
        <omgdc:Bounds x="2990" y="100" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_NotifyLogistics_Reprogram" bpmnElement="Task_NotifyLogistics_Reprogram">
        <omgdc:Bounds x="3170" y="100" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_RegisterCancellation" bpmnElement="Task_RegisterCancellation">
        <omgdc:Bounds x="2990" y="220" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_CancellationValidation" bpmnElement="Gateway_CancellationValidation">
        <omgdc:Bounds x="3170" y="235" width="50" height="50" />
        <bpmndi:BPMNLabel><omgdc:Bounds x="3155" y="292" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_AdminValidateCancellation" bpmnElement="Task_AdminValidateCancellation">
        <omgdc:Bounds x="3280" y="220" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_MarkCancelled" bpmnElement="Task_MarkCancelled">
        <omgdc:Bounds x="3460" y="220" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_NotifyRejectionForAction" bpmnElement="Task_NotifyRejectionForAction">
        <omgdc:Bounds x="3280" y="340" width="120" height="80" />
      </bpmndi:BPMNShape>

<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             id="Definitions_Logistics" 
             targetNamespace="http://bpmn.io/bpmn" 
             exporter="bpmn-js" 
             exporterVersion="18.13.2">
  <process id="Logistics_Process" name="Proceso Logístico - Ticket a Ruta" isExecutable="false">
    <!-- Inicio -->
    <startEvent id="Start_TicketCreated" name="Ticket creado (Mostrador)">
      <outgoing>Flow_CheckTicketExists</outgoing>
    </startEvent>
    <task id="Task_CheckTicketExists" name="Verificar existencia de ticket (Ingestor)">
      <incoming>Flow_CheckTicketExists</incoming>
      <outgoing>Flow_TicketExists_Gateway</outgoing>
    </task>
    <sequenceFlow id="Flow_CheckTicketExists" sourceRef="Start_TicketCreated" targetRef="Task_CheckTicketExists" />
    
    <!-- Gateway existe ticket -->
    <exclusiveGateway id="Gateway_TicketExists" name="¿Ticket en sistema?">
      <incoming>Flow_TicketExists_Gateway</incoming>
      <outgoing>Flow_NoTicket</outgoing>
      <outgoing>Flow_TicketOk</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_TicketExists_Gateway" sourceRef="Task_CheckTicketExists" targetRef="Gateway_TicketExists" />
    
    <!-- No ticket -->
    <task id="Task_RejectDelivery" name="Rechazar entrega / Notificar (Mostrador)">
      <incoming>Flow_NoTicket</incoming>
      <outgoing>Flow_End_NoTicket</outgoing>
    </task>
    <sequenceFlow id="Flow_NoTicket" sourceRef="Gateway_TicketExists" targetRef="Task_RejectDelivery" />
    <endEvent id="End_NoTicket" name="Fin - Documento rechazado">
      <incoming>Flow_End_NoTicket</incoming>
    </endEvent>
    <sequenceFlow id="Flow_End_NoTicket" sourceRef="Task_RejectDelivery" targetRef="End_NoTicket" />
    
    <!-- Ticket OK -->
    <task id="Task_NotifyLogistics" name="Notificar a Logística (Orquestador)">
      <incoming>Flow_TicketOk</incoming>
      <outgoing>Flow_DivideIntoDispatches</outgoing>
    </task>
    <sequenceFlow id="Flow_TicketOk" sourceRef="Gateway_TicketExists" targetRef="Task_NotifyLogistics" />
    
    <task id="Task_DivideCreateRoute" name="Dividir pedido en despachos y crear Ruta (Planner)">
      <incoming>Flow_DivideIntoDispatches</incoming>
      <outgoing>Flow_AssignSurtido</outgoing>
    </task>
    <sequenceFlow id="Flow_DivideIntoDispatches" sourceRef="Task_NotifyLogistics" targetRef="Task_DivideCreateRoute" />
    
    <task id="Task_AssignSurtido" name="Asignar encargado de surtido (Surtido Manager)">
      <incoming>Flow_AssignSurtido</incoming>
      <outgoing>Flow_WaitSurtido</outgoing>
    </task>
    <sequenceFlow id="Flow_AssignSurtido" sourceRef="Task_DivideCreateRoute" targetRef="Task_AssignSurtido" />
    
    <!-- Subproceso surtido -->
    <subProcess id="Subprocess_Surtido" name="Surtido por encargado">
      <incoming>Flow_WaitSurtido</incoming>
      <outgoing>Flow_SurtidoComplete</outgoing>
      <startEvent id="Start_Surtido" name="Inicio surtido" />
      <task id="Task_PerformSurtido" name="Realizar surtido (Almacén o Chofer)" />
      <task id="Task_MarkSurtidoComplete" name="Marcar Surtido Completo (Encargado)" />
      <endEvent id="End_Surtido" name="Surtido completado" />
      <sequenceFlow id="flow1" sourceRef="Start_Surtido" targetRef="Task_PerformSurtido" />
      <sequenceFlow id="flow2" sourceRef="Task_PerformSurtido" targetRef="Task_MarkSurtidoComplete" />
      <sequenceFlow id="flow3" sourceRef="Task_MarkSurtidoComplete" targetRef="End_Surtido" />
    </subProcess>
    <sequenceFlow id="Flow_WaitSurtido" sourceRef="Task_AssignSurtido" targetRef="Subprocess_Surtido" />
    <sequenceFlow id="Flow_SurtidoComplete" sourceRef="Subprocess_Surtido" targetRef="Task_MarkReadyForRoute" />
    
    <task id="Task_MarkReadyForRoute" name="Marcar Despacho listo para ruta (Orquestador)">
      <incoming>Flow_SurtidoComplete</incoming>
      <outgoing>Flow_ValidationAdmin</outgoing>
    </task>
    <sequenceFlow id="Flow_ValidationAdmin" sourceRef="Task_MarkReadyForRoute" targetRef="Task_ValidateAdmin" />
    
    <task id="Task_ValidateAdmin" name="Validación administrativa (Administrativo)">
      <incoming>Flow_ValidationAdmin</incoming>
      <outgoing>Flow_AdminValidated_Gateway</outgoing>
    </task>
    <exclusiveGateway id="Gateway_AdminValidated" name="¿Validado por Administrativo?">
      <incoming>Flow_AdminValidated_Gateway</incoming>
      <outgoing>Flow_AdminReject</outgoing>
      <outgoing>Flow_AdminOk</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_AdminValidated_Gateway" sourceRef="Task_ValidateAdmin" targetRef="Gateway_AdminValidated" />
    
    <task id="Task_AdminReject" name="Registrar rechazo de validación (Administrativo)">
      <incoming>Flow_AdminReject</incoming>
      <outgoing>Flow_HandleRejectAfterValidation</outgoing>
    </task>
    <sequenceFlow id="Flow_AdminReject" sourceRef="Gateway_AdminValidated" targetRef="Task_AdminReject" />
    <sequenceFlow id="Flow_HandleRejectAfterValidation" sourceRef="Task_AdminReject" targetRef="Task_HandleIncidence" />
    <sequenceFlow id="Flow_AdminOk" sourceRef="Gateway_AdminValidated" targetRef="Task_AssignToDriver" />
    
    <task id="Task_AssignToDriver" name="Asignar a chofer y marcar EN_RUTA (Orquestador)">
      <incoming>Flow_AdminOk</incoming>
      <outgoing>Flow_DriverDeparture</outgoing>
    </task>
    <sequenceFlow id="Flow_DriverDeparture" sourceRef="Task_AssignToDriver" targetRef="Task_DriverDeparture" />
    
    <task id="Task_DriverDeparture" name="Registrar salida CEDIS (Chofer)">
      <incoming>Flow_DriverDeparture</incoming>
      <outgoing>Flow_DeliverySubprocess</outgoing>
    </task>
    
    <!-- Subproceso entrega -->
    <subProcess id="Subprocess_Delivery" name="Entrega por chofer">
      <incoming>Flow_DeliverySubprocess</incoming>
      <outgoing>Flow_DeliveryCompleteGateway</outgoing>
      <startEvent id="Start_Delivery" name="Inicio entrega" />
      <task id="Task_PerformDelivery" name="Realizar entrega; subir evidencia" />
      <exclusiveGateway id="Gateway_DeliveryResult" name="¿Entrega total / parcial / rechazo?" />
      <task id="Task_RegisterPartialDelivery" name="Registrar entrega parcial" />
      <task id="Task_RegisterFullDelivery" name="Registrar entrega total" />
      <task id="Task_RegisterRejection" name="Registrar rechazo parcial / disputa" />
      <endEvent id="End_Delivery" name="Fin entrega" />
      <sequenceFlow id="dflow1" sourceRef="Start_Delivery" targetRef="Task_PerformDelivery" />
      <sequenceFlow id="dflow2" sourceRef="Task_PerformDelivery" targetRef="Gateway_DeliveryResult" />
      <sequenceFlow id="dflow3" sourceRef="Gateway_DeliveryResult" targetRef="Task_RegisterFullDelivery" />
      <sequenceFlow id="dflow4" sourceRef="Gateway_DeliveryResult" targetRef="Task_RegisterPartialDelivery" />
      <sequenceFlow id="dflow5" sourceRef="Gateway_DeliveryResult" targetRef="Task_RegisterRejection" />
      <sequenceFlow id="dflow6" sourceRef="Task_RegisterFullDelivery" targetRef="End_Delivery" />
      <sequenceFlow id="dflow7" sourceRef="Task_RegisterPartialDelivery" targetRef="End_Delivery" />
      <sequenceFlow id="dflow8" sourceRef="Task_RegisterRejection" targetRef="End_Delivery" />
    </subProcess>
    <sequenceFlow id="Flow_DeliverySubprocess" sourceRef="Task_DriverDeparture" targetRef="Subprocess_Delivery" />
    <sequenceFlow id="Flow_DeliveryCompleteGateway" sourceRef="Subprocess_Delivery" targetRef="Gateway_DeliveryOutcome" />
    
    <exclusiveGateway id="Gateway_DeliveryOutcome" name="¿Incidencia?">
      <incoming>Flow_DeliveryCompleteGateway</incoming>
      <outgoing>Flow_NoIncidence</outgoing>
      <outgoing>Flow_Incidence</outgoing>
    </exclusiveGateway>
    
    <task id="Task_MarkConfirmed" name="Marcar despacho confirmado (Orquestador)">
      <incoming>Flow_NoIncidence</incoming>
      <outgoing>Flow_CheckTicketCompletion_Confirmed</outgoing>
    </task>
    <sequenceFlow id="Flow_NoIncidence" sourceRef="Gateway_DeliveryOutcome" targetRef="Task_MarkConfirmed" />
    
    <task id="Task_HandleIncidence" name="Procesar incidencia (Exception Agent)">
      <incoming>Flow_Incidence</incoming>
      <incoming>Flow_HandleRejectAfterValidation</incoming>
      <incoming>Flow_NotifyRejectionForAction</incoming>
      <incoming>Flow_EscalationBack</incoming>
      <outgoing>Flow_IncidenceDecision</outgoing>
    </task>
    <sequenceFlow id="Flow_Incidence" sourceRef="Gateway_DeliveryOutcome" targetRef="Task_HandleIncidence" />
    
    <exclusiveGateway id="Gateway_IncidenceDecision" name="¿Reprogramar o Cancelar?">
      <incoming>Flow_IncidenceDecision</incoming>
      <outgoing>Flow_Reprogram</outgoing>
      <outgoing>Flow_Cancel</outgoing>
      <outgoing>Flow_Escalar</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_IncidenceDecision" sourceRef="Task_HandleIncidence" targetRef="Gateway_IncidenceDecision" />
    
    <task id="Task_CreateReprogramDispatch" name="Crear despacho de reprogramación">
      <incoming>Flow_Reprogram</incoming>
      <outgoing>Flow_NotifyLogistics_Reprogram</outgoing>
    </task>
    <sequenceFlow id="Flow_Reprogram" sourceRef="Gateway_IncidenceDecision" targetRef="Task_CreateReprogramDispatch" />
    
    <task id="Task_NotifyLogistics_Reprogram" name="Notificar a Logística para reprogramación">
      <incoming>Flow_NotifyLogistics_Reprogram</incoming>
      <outgoing>Flow_AssignSurtido_Reprogram</outgoing>
    </task>
    <sequenceFlow id="Flow_NotifyLogistics_Reprogram" sourceRef="Task_CreateReprogramDispatch" targetRef="Task_NotifyLogistics_Reprogram" />
    <sequenceFlow id="Flow_AssignSurtido_Reprogram" sourceRef="Task_NotifyLogistics_Reprogram" targetRef="Task_AssignSurtido" />
    
    <task id="Task_RegisterCancellation" name="Registrar cancelación y evidencia">
      <incoming>Flow_Cancel</incoming>
      <outgoing>Flow_ToCancellationValidation</outgoing>
    </task>
    <sequenceFlow id="Flow_Cancel" sourceRef="Gateway_IncidenceDecision" targetRef="Task_RegisterCancellation" />
    
    <exclusiveGateway id="Gateway_CancellationValidation" name="¿Cancelación validada?">
      <incoming>Flow_ToCancellationValidation</incoming>
      <outgoing>Flow_CancellationConfirmed</outgoing>
      <outgoing>Flow_CancellationRejected</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_ToCancellationValidation" sourceRef="Task_RegisterCancellation" targetRef="Gateway_CancellationValidation" />
    
    <task id="Task_AdminValidateCancellation" name="Validar cancelación (Administrativo)">
      <incoming>Flow_CancellationConfirmed</incoming>
      <outgoing>Flow_AdminValidatedCancellation</outgoing>
    </task>
    <sequenceFlow id="Flow_CancellationConfirmed" sourceRef="Gateway_CancellationValidation" targetRef="Task_AdminValidateCancellation" />
    
    <task id="Task_MarkCancelled" name="Marcar despacho cancelado (Orquestador)">
      <incoming>Flow_AdminValidatedCancellation</incoming>
      <outgoing>Flow_CheckTicketCompletion_Cancelled</outgoing>
    </task>
    <sequenceFlow id="Flow_AdminValidatedCancellation" sourceRef="Task_AdminValidateCancellation" targetRef="Task_MarkCancelled" />
    
    <task id="Task_NotifyRejectionForAction" name="Notificar rechazo de cancelación y proponer acción">
      <incoming>Flow_CancellationRejected</incoming>
      <outgoing>Flow_NotifyRejectionForAction</outgoing>
    </task>
    <sequenceFlow id="Flow_CancellationRejected" sourceRef="Gateway_CancellationValidation" targetRef="Task_NotifyRejectionForAction" />
    <sequenceFlow id="Flow_NotifyRejectionForAction" sourceRef="Task_NotifyRejectionForAction" targetRef="Task_HandleIncidence" />
    
    <task id="Task_Escalation" name="Escalar a supervisor / administrativo">
      <incoming>Flow_Escalar</incoming>
      <outgoing>Flow_EscalationBack</outgoing>
    </task>
    <sequenceFlow id="Flow_Escalar" sourceRef="Gateway_IncidenceDecision" targetRef="Task_Escalation" />
    <sequenceFlow id="Flow_EscalationBack" sourceRef="Task_Escalation" targetRef="Task_HandleIncidence" />
    
    <task id="Task_CheckTicketCompletion" name="Verificar si todos los despachos del ticket están completados o cancelados">
      <incoming>Flow_CheckTicketCompletion_Confirmed</incoming>
      <incoming>Flow_CheckTicketCompletion_Cancelled</incoming>
      <outgoing>Flow_TicketComplete_Gateway</outgoing>
    </task>
    <sequenceFlow id="Flow_CheckTicketCompletion_Confirmed" sourceRef="Task_MarkConfirmed" targetRef="Task_CheckTicketCompletion" />
    <sequenceFlow id="Flow_CheckTicketCompletion_Cancelled" sourceRef="Task_MarkCancelled" targetRef="Task_CheckTicketCompletion" />
    
    <exclusiveGateway id="Gateway_TicketComplete" name="¿Todos los despachos completados o cancelados?">
      <incoming>Flow_TicketComplete_Gateway</incoming>
      <outgoing>Flow_TicketNotComplete</outgoing>
      <outgoing>Flow_TicketComplete</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Flow_TicketComplete_Gateway" sourceRef="Task_CheckTicketCompletion" targetRef="Gateway_TicketComplete" />
    
    <task id="Task_TicketPartial" name="Marcar ticket como Parcial (Orquestador)">
      <incoming>Flow_TicketNotComplete</incoming>
      <outgoing>Flow_End_Partial</outgoing>
    </task>
    <sequenceFlow id="Flow_TicketNotComplete" sourceRef="Gateway_TicketComplete" targetRef="Task_TicketPartial" />
    <endEvent id="End_Partial" name="Fin - Ticket Parcial">
      <incoming>Flow_End_Partial</incoming>
    </endEvent>
    <sequenceFlow id="Flow_End_Partial" sourceRef="Task_TicketPartial" targetRef="End_Partial" />
    
    <task id="Task_MarkTicketDelivered" name="Marcar ticket ENTREGADO (Orquestador)">
      <incoming>Flow_TicketComplete</incoming>
      <outgoing>Flow_End_TicketDelivered</outgoing>
    </task>
    <sequenceFlow id="Flow_TicketComplete" sourceRef="Gateway_TicketComplete" targetRef="Task_MarkTicketDelivered" />
    <endEvent id="End_TicketDelivered" name="Fin - Ticket Entregado">
      <incoming>Flow_End_TicketDelivered</incoming>
    </endEvent>
    <sequenceFlow id="Flow_End_TicketDelivered" sourceRef="Task_MarkTicketDelivered" targetRef="End_TicketDelivered" />
  </process>
  
